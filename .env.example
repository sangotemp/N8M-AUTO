# n8n Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to the repository

# RECOMMENDED: Use 1Password op:// references for credentials
# See: docs/1PASSWORD_SETUP.md and TEST_RESULTS.md

# n8n Authentication
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=op://Programing/n8n-admin-test/username
N8N_BASIC_AUTH_PASSWORD=op://Programing/n8n-admin-test/password

# Alternative: Replace op:// references with actual values (not recommended)
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=your-secure-password-here

# n8n Network
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false

# Timezone
GENERIC_TIMEZONE=America/Montreal
TZ=America/Montreal
